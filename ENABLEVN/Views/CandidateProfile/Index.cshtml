@model CandidateProfileResult

@{
    ViewData["Title"] = "Hồ sơ ứng viên";
}

<section class="evn-section">
    <div class="container">
        <div class="d-flex flex-column flex-lg-row justify-content-between gap-3 mb-4">
            <div>
                <span class="evn-badge mb-3">Candidate Profile</span>
                <h1 class="fw-bold display-6 mb-2">@Model.FullName</h1>
                <p class="evn-muted mb-0">
                    Quản lý hồ sơ, CV và quyền riêng tư thông tin khuyết tật.
                </p>
            </div>

            <div class="d-flex flex-wrap gap-2 align-items-start">
                <a class="btn btn-primary evn-btn-primary" asp-action="Edit">
                    Cập nhật hồ sơ
                </a>

                <a class="btn btn-outline-dark" asp-action="Disability">
                    Thông tin khuyết tật
                </a>
            </div>
        </div>

        <div class="row g-4">
            <div class="col-lg-7">
                <div class="evn-card p-4 h-100">
                    <h4 class="fw-bold mb-3">Thông tin cá nhân</h4>

                    <div class="d-grid gap-3">
                        <div>
                            <div class="evn-muted small">Họ tên</div>
                            <div class="fw-semibold">@Model.FullName</div>
                        </div>

                        <div>
                            <div class="evn-muted small">CV</div>
                            @if (!string.IsNullOrWhiteSpace(Model.CvUrl))
                            {
                                <a href="@Model.CvUrl" target="_blank" rel="noopener">
                                    Xem CV
                                </a>
                            }
                            else
                            {
                                <span class="evn-muted">Chưa cập nhật CV</span>
                            }
                        </div>

                        <div>
                            <div class="evn-muted small">Giới thiệu</div>
                            <p class="mb-0">
                                @(string.IsNullOrWhiteSpace(Model.Bio)
                                    ? "Chưa có giới thiệu."
                                    : Model.Bio)
                            </p>
                        </div>
                    </div>
                </div>
            </div>

            <div class="col-lg-5">
                <div class="evn-card p-4 h-100">
                    <h4 class="fw-bold mb-3">Quyền riêng tư</h4>

                    <div class="d-grid gap-3">
                        <div class="evn-card-soft p-3">
                            <div class="d-flex justify-content-between gap-3">
                                <span>Trạng thái hồ sơ</span>
                                <strong>@(Model.IsPublicProfile ? "Public" : "Private")</strong>
                            </div>

                            <div class="mt-3">
                                @if (Model.IsPublicProfile)
                                {
                                    <form asp-action="MakePrivate" method="post">
                                        <button class="btn btn-outline-dark btn-sm" type="submit">
                                            Chuyển về riêng tư
                                        </button>
                                    </form>
                                }
                                else
                                {
                                    <form asp-action="MakePublic" method="post">
                                        <button class="btn btn-primary btn-sm evn-btn-primary" type="submit">
                                            Public hồ sơ
                                        </button>
                                    </form>
                                }
                            </div>
                        </div>

                        <div class="evn-card-soft p-3">
                            <div class="d-flex justify-content-between gap-3">
                                <span>Thông tin khuyết tật</span>
                                <strong>@(Model.IsDisabilityInfoVisibleToEmployer ? "Đang hiển thị" : "Đang ẩn")</strong>
                            </div>

                            <p class="evn-muted small mt-2 mb-3">
                                Bạn có toàn quyền quyết định nhà tuyển dụng có được xem thông tin này hay không.
                            </p>

                            @if (Model.IsDisabilityInfoVisibleToEmployer)
                            {
                                <form asp-action="HideDisabilityInfo" method="post">
                                    <button class="btn btn-outline-dark btn-sm" type="submit">
                                        Ẩn khỏi nhà tuyển dụng
                                    </button>
                                </form>
                            }
                            else
                            {
                                <form asp-action="ShowDisabilityInfo" method="post">
                                    <button class="btn btn-primary btn-sm evn-btn-primary" type="submit">
                                        Cho phép hiển thị
                                    </button>
                                </form>
                            }
                        </div>

                        <div class="evn-card-soft p-3">
                            <div class="evn-muted small">Mô tả thông tin khuyết tật</div>
                            <p class="mb-0">
                                @(string.IsNullOrWhiteSpace(Model.DisabilityDescription)
                                    ? "Chưa cập nhật."
                                    : Model.DisabilityDescription)
                            </p>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>