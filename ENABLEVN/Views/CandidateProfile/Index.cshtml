@model CandidateProfileResult
@{
    ViewData["Title"] = "Hồ sơ của tôi";
    var crumb = new BreadcrumbModel { MiddleText = "Dashboard", MiddleController = "CandidateDashboard", MiddleAction = "Index", CurrentText = "Hồ sơ của tôi" };
}

<div class="evn-page">
    <div class="container">
        <partial name="_Breadcrumb" model="crumb" />

        <div class="evn-card p-4 p-lg-5 mb-4 evn-card--highlight">
            <div class="d-flex flex-column flex-lg-row justify-content-between gap-3 align-items-start">
                <div>
                    <span class="evn-badge mb-2">Candidate profile</span>
                    <h1 class="evn-page-head__title mb-2">@Model.FullName</h1>
                    <p class="evn-muted mb-0">Quản lý hồ sơ, CV và quyền riêng tư thông tin hỗ trợ cá nhân.</p>
                </div>
                @if (!string.IsNullOrWhiteSpace(Model.AvatarUrl))
                {
                    <img src="@Model.AvatarUrl" alt="Ảnh đại diện" class="rounded-circle" style="width:72px;height:72px;object-fit:cover;" />
                }
                <div class="d-flex flex-wrap gap-2">
                    <a class="btn btn-primary evn-btn-primary" asp-action="Edit">
                        <i class="bi bi-pencil-square me-1" aria-hidden="true"></i> Cập nhật hồ sơ
                    </a>
                    <a class="btn btn-outline-secondary evn-btn-outline" asp-action="Disability">
                        <i class="bi bi-shield-lock me-1" aria-hidden="true"></i> Thông tin khuyết tật
                    </a>
                </div>
            </div>
        </div>

        <div class="row g-4">
            <div class="col-lg-7">
                <div class="evn-card p-4 h-100">
                    <h2 class="h5 fw-bold mb-3">Thông tin cá nhân</h2>
                    <dl class="row mb-0">
                        <dt class="col-sm-4 evn-muted small">Họ tên</dt>
                        <dd class="col-sm-8 fw-semibold">@Model.FullName</dd>
                        <dt class="col-sm-4 evn-muted small">Ngày sinh</dt>
                        <dd class="col-sm-8">@(Model.DateOfBirth?.ToString("dd/MM/yyyy") ?? "Chưa cập nhật")</dd>
                        <dt class="col-sm-4 evn-muted small">Giới tính</dt>
                        <dd class="col-sm-8">@(Model.Gender ?? "Chưa cập nhật")</dd>
                        <dt class="col-sm-4 evn-muted small">Điện thoại</dt>
                        <dd class="col-sm-8">@(Model.PhoneNumber ?? "Chưa cập nhật")</dd>
                        <dt class="col-sm-4 evn-muted small">Email liên hệ</dt>
                        <dd class="col-sm-8">@(Model.ContactEmail ?? "Chưa cập nhật")</dd>
                        <dt class="col-sm-4 evn-muted small">Địa chỉ</dt>
                        <dd class="col-sm-8">@(Model.Address ?? "Chưa cập nhật")</dd>
                        <dt class="col-sm-4 evn-muted small">Vị trí mong muốn</dt>
                        <dd class="col-sm-8">@(Model.DesiredPosition ?? "Chưa cập nhật")</dd>
                        <dt class="col-sm-4 evn-muted small">Lương mong muốn</dt>
                        <dd class="col-sm-8">@(Model.DesiredSalary?.ToString("N0") ?? "Chưa cập nhật")</dd>
                        <dt class="col-sm-4 evn-muted small">CV</dt>
                        <dd class="col-sm-8">
                            @if (!string.IsNullOrWhiteSpace(Model.CvUrl))
                            {
                                <a href="@Model.CvUrl" target="_blank" rel="noopener">Xem CV <span class="visually-hidden">(mở tab mới)</span></a>
                            }
                            else
                            {
                                <span class="evn-muted">Chưa cập nhật CV</span>
                            }
                        </dd>
                        <dt class="col-sm-4 evn-muted small">Giới thiệu</dt>
                        <dd class="col-sm-8">
                            @(string.IsNullOrWhiteSpace(Model.Bio) ? "Chưa có giới thiệu." : Model.Bio)
                        </dd>
                        <dt class="col-sm-4 evn-muted small">Kinh nghiệm</dt>
                        <dd class="col-sm-8">@(string.IsNullOrWhiteSpace(Model.ExperienceSummary) ? "Chưa cập nhật" : Model.ExperienceSummary)</dd>
                        <dt class="col-sm-4 evn-muted small">Kỹ năng</dt>
                        <dd class="col-sm-8">@(string.IsNullOrWhiteSpace(Model.Skills) ? "Chưa cập nhật" : Model.Skills)</dd>
                        <dt class="col-sm-4 evn-muted small">Học vấn</dt>
                        <dd class="col-sm-8">@(string.IsNullOrWhiteSpace(Model.Education) ? "Chưa cập nhật" : Model.Education)</dd>
                        <dt class="col-sm-4 evn-muted small">Chứng chỉ</dt>
                        <dd class="col-sm-8">@(string.IsNullOrWhiteSpace(Model.Certifications) ? "Chưa cập nhật" : Model.Certifications)</dd>
                        <dt class="col-sm-4 evn-muted small">Portfolio</dt>
                        <dd class="col-sm-8">@(string.IsNullOrWhiteSpace(Model.PortfolioUrl) ? "Chưa cập nhật" : Model.PortfolioUrl)</dd>
                        <dt class="col-sm-4 evn-muted small">Trạng thái tìm việc</dt>
                        <dd class="col-sm-8">@(Model.JobSeekingStatus ?? "Chưa cập nhật")</dd>
                        <dt class="col-sm-4 evn-muted small">Hình thức làm việc</dt>
                        <dd class="col-sm-8">@(Model.DesiredWorkMode ?? "Chưa cập nhật")</dd>
                        <dt class="col-sm-4 evn-muted small">Nhu cầu tiếp cận</dt>
                        <dd class="col-sm-8">@(string.IsNullOrWhiteSpace(Model.AccessibilityNeeds) ? "Chưa cập nhật" : Model.AccessibilityNeeds)</dd>
                    </dl>
                </div>
            </div>
            <div class="col-lg-5">
                <div class="evn-card p-4 h-100">
                    <h2 class="h5 fw-bold mb-3">Quyền riêng tư</h2>
                    <div class="d-grid gap-3">
                        <div class="evn-card-soft p-3">
                            <div class="d-flex justify-content-between align-items-center gap-2 mb-2">
                                <span class="fw-semibold">Trạng thái hồ sơ</span>
                                <span class="evn-tag">@(Model.IsPublicProfile ? "Công khai" : "Riêng tư")</span>
                            </div>
                            @if (Model.IsPublicProfile)
                            {
                                <form asp-action="MakePrivate" method="post">
                                    @Html.AntiForgeryToken()
                                    <button class="btn btn-outline-secondary btn-sm w-100" type="submit">Chuyển về riêng tư</button>
                                </form>
                            }
                            else
                            {
                                <form asp-action="MakePublic" method="post">
                                    @Html.AntiForgeryToken()
                                    <button class="btn btn-primary btn-sm evn-btn-primary w-100" type="submit">Public hồ sơ</button>
                                </form>
                            }
                        </div>

                        <div class="evn-card-soft p-3">
                            <div class="d-flex justify-content-between align-items-center gap-2 mb-2">
                                <span class="fw-semibold">Thông tin khuyết tật (với NTD)</span>
                                <span class="evn-tag @(Model.IsDisabilityInfoVisibleToEmployer ? "evn-tag" : "evn-tag--neutral")">
                                    @(Model.IsDisabilityInfoVisibleToEmployer ? "Đang hiển thị" : "Đang ẩn")
                                </span>
                            </div>
                            <p class="evn-muted small mb-3">Bạn có toàn quyền quyết định nhà tuyển dụng có được xem thông tin này hay không.</p>
                            @if (Model.IsDisabilityInfoVisibleToEmployer)
                            {
                                <form asp-action="HideDisabilityInfo" method="post">
                                    @Html.AntiForgeryToken()
                                    <button class="btn btn-outline-secondary btn-sm w-100" type="submit">Ẩn khỏi nhà tuyển dụng</button>
                                </form>
                            }
                            else
                            {
                                <form asp-action="ShowDisabilityInfo" method="post">
                                    @Html.AntiForgeryToken()
                                    <button class="btn btn-sm w-100 evn-btn-accent text-white" type="submit">Cho phép hiển thị</button>
                                </form>
                            }
                        </div>

                        <div class="evn-card-soft p-3">
                            <h3 class="h6 fw-bold mb-2">Mô tả thông tin hỗ trợ</h3>
                            @if (!Model.IsDisabilityInfoVisibleToEmployer)
                            {
                                <p class="small mb-2 p-2 rounded-2" role="status" style="background: var(--evn-surface-muted); border: 1px solid var(--evn-border);">
                                    <strong>Đang ẩn với nhà tuyển dụng.</strong> Chỉ bạn thấy nội dung bên dưới. Cập nhật tại <a asp-action="Disability">Thông tin khuyết tật</a>.
                                </p>
                            }
                            <p class="mb-0">
                                @(string.IsNullOrWhiteSpace(Model.DisabilityDescription) ? "Chưa cập nhật." : Model.DisabilityDescription)
                            </p>
                        </div>

                        @if (string.IsNullOrWhiteSpace(Model.CvUrl) || string.IsNullOrWhiteSpace(Model.Bio))
                        {
                            <div class="border rounded-3 p-3 small" style="border-color: var(--evn-warning-border) !important; background: var(--evn-warning-soft); color: var(--evn-warning-text);" role="status">
                                <strong>Thiếu thông tin.</strong>
                                Hoàn thiện <a asp-action="Edit">hồ sơ</a> để tăng cơ hội được nhà tuyển dụng liên hệ.
                            </div>
                        }
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
