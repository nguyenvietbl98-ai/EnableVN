@model UpdateCandidateProfileCommand

@{
    ViewData["Title"] = "Cập nhật hồ sơ ứng viên";
    var crumb = new BreadcrumbModel { MiddleText = "Hồ sơ", MiddleController = "CandidateProfile", MiddleAction = "Index", CurrentText = "Chỉnh sửa" };
}

<div class="evn-page">
    <div class="container py-4">
        <partial name="_Breadcrumb" model="crumb" />
        <div class="row justify-content-center">
            <div class="col-lg-7">
                <div class="evn-card evn-form p-4 p-lg-5">
                    <span class="evn-badge mb-3">Candidate</span>
                    <h1 class="h3 fw-bold mb-2">Cập nhật hồ sơ ứng viên</h1>
                    <p class="evn-muted mb-4">
                        Cập nhật thông tin cá nhân và CV của bạn.
                    </p>

                    <form asp-action="Edit" method="post" enctype="multipart/form-data">
                        @Html.AntiForgeryToken()
                        <div asp-validation-summary="ModelOnly" class="text-danger small mb-3" role="alert" aria-live="assertive" aria-atomic="true"></div>
                        <div class="mb-3">
                            <label asp-for="FullName" class="form-label">Họ và tên</label>
                            <input asp-for="FullName" class="form-control" />
                            <span asp-validation-for="FullName" class="text-danger small" role="status" aria-live="polite"></span>
                        </div>

                        <div class="row g-3">
                            <div class="col-md-6">
                                <label class="form-label" for="candidate-avatar-file">Ảnh đại diện</label>
                                <input id="candidate-avatar-file" type="file" name="avatarFile" class="form-control" accept=".jpg,.jpeg,.png,.webp" />
                                <input type="hidden" asp-for="AvatarUrl" />
                            </div>
                            <div class="col-md-6"><label asp-for="DateOfBirth" class="form-label">Ngày sinh</label><input asp-for="DateOfBirth" type="date" class="form-control" /></div>
                            <div class="col-md-6"><label asp-for="Gender" class="form-label">Giới tính</label><input asp-for="Gender" class="form-control" /></div>
                            <div class="col-md-6"><label asp-for="PhoneNumber" class="form-label">Số điện thoại</label><input asp-for="PhoneNumber" class="form-control" /></div>
                            <div class="col-md-6"><label asp-for="ContactEmail" class="form-label">Email liên hệ</label><input asp-for="ContactEmail" class="form-control" /></div>
                            <div class="col-md-6"><label asp-for="Address" class="form-label">Địa chỉ / tỉnh thành</label><input asp-for="Address" class="form-control" /></div>
                            <div class="col-md-6"><label asp-for="DesiredPosition" class="form-label">Vị trí mong muốn</label><input asp-for="DesiredPosition" class="form-control" /></div>
                            <div class="col-md-6"><label asp-for="DesiredSalary" class="form-label">Mức lương mong muốn</label><input asp-for="DesiredSalary" type="number" class="form-control" /></div>
                            <div class="col-12"><label asp-for="ExperienceSummary" class="form-label">Kinh nghiệm</label><textarea asp-for="ExperienceSummary" class="form-control" rows="3"></textarea></div>
                            <div class="col-12"><label asp-for="Skills" class="form-label">Kỹ năng</label><textarea asp-for="Skills" class="form-control" rows="3"></textarea></div>
                            <div class="col-12"><label asp-for="Education" class="form-label">Học vấn</label><textarea asp-for="Education" class="form-control" rows="3"></textarea></div>
                            <div class="col-12"><label asp-for="Certifications" class="form-label">Chứng chỉ</label><textarea asp-for="Certifications" class="form-control" rows="3"></textarea></div>
                            <div class="col-md-6"><label asp-for="PortfolioUrl" class="form-label">Portfolio / GitHub / LinkedIn</label><input asp-for="PortfolioUrl" class="form-control" /></div>
                            <div class="col-md-6">
                                <label class="form-label" for="candidate-cv-file">CV upload</label>
                                <input id="candidate-cv-file" type="file" name="cvFile" accept=".pdf,.doc,.docx" class="form-control" />
                                <input type="hidden" asp-for="CvUrl" />
                            </div>
                            <div class="col-md-6"><label asp-for="JobSeekingStatus" class="form-label">Trạng thái tìm việc</label><input asp-for="JobSeekingStatus" class="form-control" /></div>
                            <div class="col-md-6"><label asp-for="DesiredWorkMode" class="form-label">Hình thức làm việc mong muốn</label><input asp-for="DesiredWorkMode" class="form-control" /></div>
                            <div class="col-12"><label asp-for="AccessibilityNeeds" class="form-label">Nhu cầu hỗ trợ tiếp cận</label><textarea asp-for="AccessibilityNeeds" class="form-control" rows="3"></textarea></div>
                        </div>

                        <div class="mb-4 mt-3">
                            <label asp-for="Bio" class="form-label">Giới thiệu bản thân</label>
                            <textarea asp-for="Bio" class="form-control" rows="5"></textarea>
                        </div>

                        <button class="btn btn-primary evn-btn-primary" type="submit">
                            Lưu thay đổi
                        </button>

                        <a class="btn btn-outline-secondary" asp-action="Index">
                            Hủy
                        </a>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>
