@model UpdateCandidateProfileCommand

@{
    ViewData["Title"] = "Cập nhật hồ sơ ứng viên";
    var crumb = new BreadcrumbModel { MiddleText = "Hồ sơ", MiddleController = "CandidateProfile", MiddleAction = "Index", CurrentText = "Chỉnh sửa" };
}

<div class="evn-page">
    <div class="container py-4">
        <partial name="_Breadcrumb" model="crumb" />
        <div class="row justify-content-center">
            <div class="col-lg-7">
                <div class="evn-card evn-form p-4 p-lg-5">
                    <span class="evn-badge mb-3">Candidate</span>
                    <h1 class="h3 fw-bold mb-2">Cập nhật hồ sơ ứng viên</h1>
                    <p class="evn-muted mb-4">
                        Cập nhật thông tin cá nhân và CV của bạn.
                    </p>

                    <form asp-action="Edit" method="post">
                        @Html.AntiForgeryToken()
                        <div class="mb-3">
                            <label asp-for="FullName" class="form-label">Họ và tên</label>
                            <input asp-for="FullName" class="form-control" />
                        </div>

                        <div class="mb-3">
                            <label asp-for="CvUrl" class="form-label">Đường dẫn CV</label>
                            <input asp-for="CvUrl" class="form-control" />
                        </div>

                        <div class="mb-4">
                            <label asp-for="Bio" class="form-label">Giới thiệu bản thân</label>
                            <textarea asp-for="Bio" class="form-control" rows="5"></textarea>
                        </div>

                        <button class="btn btn-primary evn-btn-primary" type="submit">
                            Lưu thay đổi
                        </button>

                        <a class="btn btn-outline-secondary" asp-action="Index">
                            Hủy
                        </a>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>
