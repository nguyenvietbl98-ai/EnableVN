@model UpdateEmployerProfileCommand

@{
    ViewData["Title"] = "Cập nhật hồ sơ doanh nghiệp";
    var crumb = new BreadcrumbModel { MiddleText = "Hồ sơ NTD", MiddleController = "EmployerProfile", MiddleAction = "Index", CurrentText = "Chỉnh sửa" };
}

<div class="evn-page">
    <div class="container py-4">
        <partial name="_Breadcrumb" model="crumb" />
        <div class="row justify-content-center">
            <div class="col-lg-8">
                <div class="evn-card evn-form p-4 p-lg-5">
                    <span class="evn-badge mb-3">Employer</span>
                    <h1 class="h3 fw-bold mb-2">Cập nhật hồ sơ doanh nghiệp</h1>
                    <p class="evn-muted mb-4">
                        Cập nhật thông tin doanh nghiệp và các hỗ trợ tiếp cận.
                    </p>

                    <form asp-action="Edit" method="post" enctype="multipart/form-data">
                        @Html.AntiForgeryToken()
                        <partial name="_EmployerProfileForm" model="Model" />

                        <button class="btn btn-primary evn-btn-primary" type="submit">
                            Lưu thay đổi
                        </button>

                        <a class="btn btn-outline-secondary" asp-action="Index">
                            Hủy
                        </a>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>
