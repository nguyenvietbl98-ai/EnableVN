@model CreateEmployerProfileCommand

@{
    ViewData["Title"] = "Tạo hồ sơ doanh nghiệp";
    var crumb = new BreadcrumbModel { MiddleText = "Dashboard", MiddleController = "EmployerDashboard", MiddleAction = "Index", CurrentText = "Tạo hồ sơ NTD" };
}

<div class="evn-page">
    <div class="container py-4">
        <partial name="_Breadcrumb" model="crumb" />
        <div class="row justify-content-center">
            <div class="col-lg-8">
                <div class="evn-card evn-form p-4 p-lg-5">
                    <span class="evn-badge mb-3">Employer</span>
                    <h1 class="h3 fw-bold mb-2">Tạo hồ sơ doanh nghiệp</h1>
                    <p class="evn-muted mb-4">
                        Bạn cần có hồ sơ doanh nghiệp trước khi đăng tin tuyển dụng.
                    </p>

                    <form asp-action="Create" method="post">
                        @Html.AntiForgeryToken()
                        <partial name="_EmployerProfileForm" model="Model" />

                        <button class="btn btn-primary evn-btn-primary" type="submit">
                            Tạo hồ sơ
                        </button>

                        <a class="btn btn-outline-secondary" asp-controller="Home" asp-action="Index">
                            Hủy
                        </a>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>
