@model dynamic

<div class="mb-3">
    <label class="form-label">Tên doanh nghiệp</label>
    <input name="CompanyName" value="@Model.CompanyName" class="form-control" placeholder="VD: Công ty TNHH EnableVN" />
</div>

<div class="mb-3">
    <label class="form-label">Website</label>
    <input name="WebsiteUrl" value="@Model.WebsiteUrl" class="form-control" placeholder="https://example.com" />
</div>

<div class="mb-4">
    <label class="form-label">Mô tả doanh nghiệp</label>
    <textarea name="Description" class="form-control" rows="4">@Model.Description</textarea>
</div>

<hr class="my-4" />

<h5 class="fw-bold mb-3">Thông tin môi trường tiếp cận</h5>

<div class="row g-3 mb-4">
    <div class="col-md-6">
        <label class="form-check">
            <input name="HasWheelchairAccess" class="form-check-input" type="checkbox" value="true"
            @(Model.HasWheelchairAccess == true ? "checked" : "") />
            <input name="HasWheelchairAccess" type="hidden" value="false" />
            <span class="form-check-label">Có hỗ trợ xe lăn</span>
        </label>
    </div>

    <div class="col-md-6">
        <label class="form-check">
            <input name="HasAccessibleRestroom" class="form-check-input" type="checkbox" value="true"
            @(Model.HasAccessibleRestroom == true ? "checked" : "") />
            <input name="HasAccessibleRestroom" type="hidden" value="false" />
            <span class="form-check-label">Có nhà vệ sinh tiếp cận</span>
        </label>
    </div>

    <div class="col-md-6">
        <label class="form-check">
            <input name="SupportsFlexibleWorkingTime" class="form-check-input" type="checkbox" value="true"
            @(Model.SupportsFlexibleWorkingTime == true ? "checked" : "") />
            <input name="SupportsFlexibleWorkingTime" type="hidden" value="false" />
            <span class="form-check-label">Hỗ trợ thời gian linh hoạt</span>
        </label>
    </div>

    <div class="col-md-6">
        <label class="form-check">
            <input name="SupportsRemoteWork" class="form-check-input" type="checkbox" value="true"
            @(Model.SupportsRemoteWork == true ? "checked" : "") />
            <input name="SupportsRemoteWork" type="hidden" value="false" />
            <span class="form-check-label">Hỗ trợ làm việc từ xa</span>
        </label>
    </div>

    <div class="col-md-6">
        <label class="form-check">
            <input name="ProvidesAssistiveDevices" class="form-check-input" type="checkbox" value="true"
            @(Model.ProvidesAssistiveDevices == true ? "checked" : "") />
            <input name="ProvidesAssistiveDevices" type="hidden" value="false" />
            <span class="form-check-label">Có thiết bị hỗ trợ</span>
        </label>
    </div>
</div>