@model EmployerProfileResult

@{
    ViewData["Title"] = "Hồ sơ doanh nghiệp";
    var crumb = new BreadcrumbModel { MiddleText = "Dashboard", MiddleController = "EmployerDashboard", MiddleAction = "Index", CurrentText = "Hồ sơ doanh nghiệp" };
}

<div class="evn-page">
    <div class="container py-4">
        <partial name="_Breadcrumb" model="crumb" />
        <div class="evn-card p-4 p-lg-5 mb-4">
            <div class="d-flex flex-column flex-lg-row justify-content-between gap-3 align-items-start">
                <div>
                    <span class="evn-badge mb-2">Employer profile</span>
                    <h1 class="evn-page-head__title mb-2">@Model.CompanyName</h1>
                    <p class="evn-page-head__lead mb-0">
                        Hồ sơ doanh nghiệp và thông tin môi trường làm việc hòa nhập.
                    </p>
                </div>

                <div class="d-flex flex-wrap gap-2">
                    <a class="btn btn-primary evn-btn-primary" asp-action="Edit">Cập nhật hồ sơ</a>
                    <a class="btn btn-outline-secondary" asp-action="Details" asp-route-id="@Model.Id">Xem trang public</a>
                </div>
            </div>
        </div>

        <div class="row g-4">
            <div class="col-lg-7">
                <div class="evn-card p-4 h-100">
                    <h2 class="h5 fw-bold mb-3">Thông tin doanh nghiệp</h2>

                    <div class="d-grid gap-3">
                        <div>
                            <div class="evn-muted small">Tên doanh nghiệp</div>
                            <div class="fw-semibold">@Model.CompanyName</div>
                        </div>

                        <div>
                            <div class="evn-muted small">Website</div>
                            @if (!string.IsNullOrWhiteSpace(Model.WebsiteUrl))
                            {
                                <a href="@Model.WebsiteUrl" target="_blank" rel="noopener">
                                    @Model.WebsiteUrl <span class="visually-hidden">(mở tab mới)</span>
                                </a>
                            }
                            else
                            {
                                <span class="evn-muted">Chưa cập nhật</span>
                            }
                        </div>

                        <div>
                            <div class="evn-muted small">Mô tả</div>
                            <p class="mb-0">
                                @(string.IsNullOrWhiteSpace(Model.Description)
                                    ? "Chưa có mô tả."
                                    : Model.Description)
                            </p>
                        </div>
                    </div>
                </div>
            </div>

            <div class="col-lg-5">
                <div class="evn-card p-4 h-100">
                    <h2 class="h5 fw-bold mb-3">Môi trường tiếp cận</h2>

                    <ul class="list-unstyled d-grid gap-3 mb-0">
                        <li class="d-flex justify-content-between">
                            <span>Hỗ trợ xe lăn</span>
                            <strong>@(Model.HasWheelchairAccess ? "Có" : "Không")</strong>
                        </li>

                        <li class="d-flex justify-content-between">
                            <span>Nhà vệ sinh tiếp cận</span>
                            <strong>@(Model.HasAccessibleRestroom ? "Có" : "Không")</strong>
                        </li>

                        <li class="d-flex justify-content-between">
                            <span>Thời gian linh hoạt</span>
                            <strong>@(Model.SupportsFlexibleWorkingTime ? "Có" : "Không")</strong>
                        </li>

                        <li class="d-flex justify-content-between">
                            <span>Làm việc từ xa</span>
                            <strong>@(Model.SupportsRemoteWork ? "Có" : "Không")</strong>
                        </li>

                        <li class="d-flex justify-content-between">
                            <span>Thiết bị hỗ trợ</span>
                            <strong>@(Model.ProvidesAssistiveDevices ? "Có" : "Không")</strong>
                        </li>
                    </ul>
                </div>
            </div>
        </div>
    </div>
</div>
