@model LoginCommand

@{

    ViewData["Title"] = "Đăng nhập";

    var crumb = new BreadcrumbModel { CurrentText = "Đăng nhập" };

}



<div class="evn-page evn-auth-page">

    <div class="container">

        <partial name="_Breadcrumb" model="crumb" />

        <div class="row justify-content-center py-4 py-md-5">

            <div class="col-12 col-md-10 col-lg-5">

                <div class="evn-card evn-form evn-auth-card shadow-sm">

                    <div class="evn-auth-card__head">

                        <span class="evn-badge mb-3">Tài khoản</span>

                        <h1 class="h3 fw-bold mb-2">Đăng nhập</h1>

                        <p class="evn-muted mb-0">Truy cập tài khoản EnableVN của bạn.</p>

                    </div>



                    <environment include="Development">

                        <details class="evn-auth-dev-hint mt-3 mb-4">

                            <summary class="fw-semibold">Gợi ý tài khoản thử nghiệm</summary>

                            <div class="mt-2 small evn-muted">

                                <div><span class="text-body-secondary">Email:</span> <code class="user-select-all">admin@enablevn.local</code></div>

                                <div><span class="text-body-secondary">Mật khẩu:</span> <code class="user-select-all">Admin@123</code></div>

                            </div>

                        </details>

                    </environment>



                    <div asp-validation-summary="ModelOnly" class="text-danger small mb-3" role="alert" aria-live="assertive" aria-atomic="true"></div>



                    <form asp-action="Login" method="post" novalidate class="evn-auth-form">

                        @Html.AntiForgeryToken()

                        <input type="hidden" asp-for="ReturnUrl" />

                        <div class="evn-field mb-3">

                            <label asp-for="Email" class="form-label">Email</label>

                            <input asp-for="Email" class="form-control form-control-lg" autocomplete="username" placeholder="you@example.com" />
                            <span asp-validation-for="Email" class="text-danger small" role="status" aria-live="polite"></span>

                        </div>

                        <div class="evn-field mb-4">

                            <label asp-for="Password" class="form-label">Mật khẩu</label>

                            <input asp-for="Password" type="password" class="form-control form-control-lg" autocomplete="current-password" placeholder="••••••••" />
                            <span asp-validation-for="Password" class="text-danger small" role="status" aria-live="polite"></span>

                        </div>

                        <button class="btn btn-primary evn-btn-primary w-100 btn-lg" type="submit">Đăng nhập</button>

                    </form>



                    <p class="mt-4 mb-0 evn-muted text-center small">

                        Chưa có tài khoản?

                        <a asp-controller="Auth" asp-action="Register">Đăng ký</a>

                    </p>

                </div>

            </div>

        </div>

    </div>

</div>


