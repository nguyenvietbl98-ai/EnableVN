@model RegisterCommand

@{
    ViewData["Title"] = "Đăng ký";
}

<section class="evn-section">
    <div class="container">
        <div class="row justify-content-center">
            <div class="col-lg-5">
                <div class="evn-card evn-form">
                    <h1 class="h3 fw-bold mb-2">Tạo tài khoản</h1>
                    <p class="evn-muted mb-4">
                        Tham gia EnableVN với vai trò ứng viên hoặc nhà tuyển dụng.
                    </p>

                    <form asp-action="Register" method="post">
                        <div class="mb-3">
                            <label asp-for="Email" class="form-label">Email</label>
                            <input asp-for="Email" class="form-control" placeholder="you@example.com" />
                        </div>

                        <div class="mb-3">
                            <label asp-for="Password" class="form-label">Mật khẩu</label>
                            <input asp-for="Password" type="password" class="form-control" placeholder="••••••••" />
                        </div>

                        <div class="mb-4">
                            <label asp-for="Role" class="form-label">Vai trò</label>
                            <select asp-for="Role" class="form-select">
                                <option value="@UserRole.Candidate">Ứng viên</option>
                                <option value="@UserRole.Employer">Nhà tuyển dụng</option>
                            </select>
                        </div>

                        <button class="btn btn-primary evn-btn-primary w-100" type="submit">
                            Đăng ký
                        </button>
                    </form>

                    <p class="mt-4 mb-0 evn-muted text-center">
                        Đã có tài khoản?
                        <a asp-controller="Auth" asp-action="Login">Đăng nhập</a>
                    </p>
                </div>
            </div>
        </div>
    </div>
</section>