@{
    ViewData["Title"] = "Trợ lý AI";
    var role = ViewBag.Role as string ?? "";
    var crumb = role switch
    {
        nameof(UserRole.Candidate) => new BreadcrumbModel
        {
            CurrentText = "Trợ lý AI",
            MiddleText = "Dashboard",
            MiddleController = "CandidateDashboard",
            MiddleAction = "Index",
        },
        nameof(UserRole.Employer) => new BreadcrumbModel
        {
            CurrentText = "Trợ lý AI",
            MiddleText = "Dashboard",
            MiddleController = "EmployerDashboard",
            MiddleAction = "Index",
        },
        _ => new BreadcrumbModel { CurrentText = "Trợ lý AI" },
    };
}

<div class="evn-page">
    <div class="container py-4">
        <partial name="_Breadcrumb" model="crumb" />

        <div class="evn-card evn-form p-4 p-lg-5 evn-ai-page" data-evn-ai-role="@role">
            <div class="d-flex flex-wrap align-items-start justify-content-between gap-3 mb-3">
                <div>
                    <span class="evn-badge mb-2 d-inline-flex align-items-center gap-1">
                        <i class="bi bi-stars" aria-hidden="true"></i> AI
                    </span>
                    <h1 class="h3 fw-bold mb-2">Trợ lý AI EnableVN</h1>
                    <p class="evn-muted mb-0 small" id="evn-ai-chat-hint"></p>
                </div>
            </div>

            <div id="evn-ai-chat-log" class="evn-ai-page__log mb-4" aria-live="polite"></div>
            <div id="evn-ai-suggestions" class="d-grid gap-2 mb-4"></div>

            <form id="evn-ai-chat-form" class="mb-3">
                <label for="evn-ai-chat-input" class="form-label fw-semibold">Tin nhắn</label>
                <div class="d-flex flex-column flex-md-row gap-2 align-items-stretch align-items-md-end">
                    <textarea id="evn-ai-chat-input" class="form-control" rows="4" maxlength="4000" placeholder="Nhập mô tả của bạn…"></textarea>
                    <button type="submit" class="btn btn-primary evn-btn-primary px-4 align-self-md-stretch">Gửi</button>
                </div>
            </form>

            <p class="small evn-muted mb-0">
                Trợ lý mục 1: gợi ý từ dữ liệu EnableVN + Gemini (<code>Gemini:Model</code>, mặc định <code>gemini-flash-latest</code>). Nút bên dưới mở trang chi tiết tin hoặc hồ sơ ứng viên — vui lòng kiểm tra trước khi quyết định.
            </p>
        </div>
    </div>
</div>

@section Scripts {
    <script src="~/js/ai-assistant-page.js" asp-append-version="true"></script>
    <script>
        document.addEventListener('DOMContentLoaded', function () {
            if (window.evnAiAssistantPageInit) window.evnAiAssistantPageInit();
        });
    </script>
}
