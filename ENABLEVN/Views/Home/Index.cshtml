@{
    ViewData["Title"] = "Trang chủ";
}

<section class="evn-hero">
    <div class="container">
        <div class="row align-items-center g-5">
            <div class="col-lg-7">
                <span class="evn-badge mb-4">Tuyển dụng tiếp cận · Inclusive hiring</span>

                <h1 class="evn-hero-title mb-4">
                    Việc làm dễ tiếp cận hơn cho mọi người.
                </h1>

                <p class="evn-hero-text mb-4">
                    EnableVN kết nối ứng viên với các doanh nghiệp quan tâm đến môi trường làm việc bao trùm:
                    hỗ trợ xe lăn, làm việc từ xa, thời gian linh hoạt và thiết bị hỗ trợ.
                </p>

                <div class="d-flex flex-wrap gap-3">
                    <a class="btn btn-primary btn-lg evn-btn-primary" asp-controller="Jobs" asp-action="Index">
                        Tìm việc ngay
                    </a>

                    <a class="btn btn-outline-dark btn-lg" asp-controller="Auth" asp-action="Register">
                        Tham gia EnableVN
                    </a>
                </div>
            </div>

            <div class="col-lg-5">
                <div class="evn-card p-4">
                    <div class="d-grid gap-3">
                        <div class="evn-card-soft p-4">
                            <h5 class="fw-bold mb-1">Hỗ trợ tiếp cận</h5>
                            <p class="evn-muted mb-0">Lọc việc theo xe lăn, remote, thời gian linh hoạt.</p>
                        </div>

                        <div class="evn-card-soft p-4">
                            <h5 class="fw-bold mb-1">Quyền riêng tư</h5>
                            <p class="evn-muted mb-0">Ứng viên kiểm soát việc hiển thị thông tin khuyết tật.</p>
                        </div>

                        <div class="evn-card-soft p-4">
                            <h5 class="fw-bold mb-1">Quản lý hồ sơ</h5>
                            <p class="evn-muted mb-0">Nhà tuyển dụng theo dõi trạng thái ứng tuyển rõ ràng.</p>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>