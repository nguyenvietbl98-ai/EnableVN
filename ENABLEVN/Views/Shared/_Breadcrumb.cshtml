@model Presentation.ViewModels.Shared.BreadcrumbModel

<nav class="evn-breadcrumb" aria-label="Breadcrumb">
    <ol class="evn-breadcrumb__list">
        <li class="evn-breadcrumb__item">
            <a asp-controller="Home" asp-action="Index">Trang chủ</a>
        </li>
        @if (!string.IsNullOrEmpty(Model.MiddleText))
        {
            <li class="evn-breadcrumb__item">
                <span class="evn-breadcrumb__sep" aria-hidden="true">/</span>
                @if (!string.IsNullOrEmpty(Model.MiddleController) && !string.IsNullOrEmpty(Model.MiddleAction))
                {
                    @if (Model.MiddleRoute is { Count: > 0 })
                    {
                        <a asp-controller="@Model.MiddleController" asp-action="@Model.MiddleAction" asp-all-route-data="Model.MiddleRoute">@Model.MiddleText</a>
                    }
                    else
                    {
                        <a asp-controller="@Model.MiddleController" asp-action="@Model.MiddleAction">@Model.MiddleText</a>
                    }
                }
                else
                {
                    <span>@Model.MiddleText</span>
                }
            </li>
        }
        <li class="evn-breadcrumb__item evn-breadcrumb__item--current" aria-current="page">
            <span class="evn-breadcrumb__sep" aria-hidden="true">/</span>
            @Model.CurrentText
        </li>
    </ol>
</nav>
