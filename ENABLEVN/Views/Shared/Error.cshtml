@model Presentation.Models.ErrorViewModel
@{
    ViewData["Title"] = "Lỗi";
    var crumb = new BreadcrumbModel { CurrentText = "Lỗi" };
}

<div class="evn-page">
    <div class="container py-4">
        <partial name="_Breadcrumb" model="crumb" />
        <div class="evn-card p-4 p-lg-5" role="alert">
            <h1 class="h3 fw-bold text-danger mb-2">Đã xảy ra lỗi</h1>
            <p class="evn-muted mb-3">Ứng dụng không xử lý được yêu cầu của bạn. Vui lòng thử lại sau hoặc quay về trang chủ.</p>

            @if (Model.ShowRequestId)
            {
                <p class="mb-4">
                    <strong>Mã yêu cầu:</strong> <code>@Model.RequestId</code>
                </p>
            }

            <div class="evn-card-soft p-3 mb-0 small">
                <p class="mb-2"><strong>Chế độ phát triển:</strong> bật môi trường Development để xem chi tiết lỗi khi gỡ lỗi cục bộ.</p>
                <p class="mb-0">Không bật Development trên môi trường production vì có thể lộ thông tin nhạy cảm.</p>
            </div>

            <a class="btn btn-primary evn-btn-primary mt-4" asp-controller="Home" asp-action="Index">Về trang chủ</a>
        </div>
    </div>
</div>
