@inject Microsoft.AspNetCore.Antiforgery.IAntiforgery Antiforgery
@{
    var evnCsrf = Antiforgery.GetAndStoreTokens(Context);
}
<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="csrf-token" content="@evnCsrf.RequestToken" />

    <title>@ViewData["Title"] - EnableVN</title>

    <!-- Bootstrap 5 CDN -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" />
    <!-- Bootstrap Icons (Thêm vào để dùng icon cho đẹp) -->
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">

    <!-- CSS Custom của hệ thống -->
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/enablevn.css" asp-append-version="true" />
</head>

<body>
    <!-- Skip Link cho Screen Reader & Keyboard Navigation -->
    <a class="evn-skip-link" href="#main-content">Bỏ qua đến nội dung chính</a>
    
    <!-- Render Navbar -->
    <partial name="_Header" />

    <!-- Main Content -->
    <main id="main-content" tabindex="-1" class="min-vh-100 d-flex flex-column">
        @if (TempData["Success"] is not null || TempData["SuccessMessage"] is not null)
        {
            <div class="container mt-4 evn-alert-host">
                <div class="alert alert-success alert-dismissible fade show evn-card-soft" role="alert">
                    <i class="bi bi-check-circle-fill me-2"></i>
                    @(TempData["Success"] ?? TempData["SuccessMessage"])
                    <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                </div>
            </div>
        }

        @if (TempData["Error"] is not null || TempData["ErrorMessage"] is not null)
        {
            <div class="container mt-4 evn-alert-host">
                <div class="alert alert-danger alert-dismissible fade show evn-card-soft" role="alert">
                    <i class="bi bi-exclamation-triangle-fill me-2"></i>
                    @(TempData["Error"] ?? TempData["ErrorMessage"])
                    <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                </div>
            </div>
        }

        <div class="flex-grow-1">
            @RenderBody()
        </div>
    </main>

    <!-- Render Footer -->
    <partial name="_Footer" />

    <!-- Scripts -->
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/enablevn-accessibility.js" asp-append-version="true"></script>
    <script src="~/js/ai-recruitment.js" asp-append-version="true"></script>

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>