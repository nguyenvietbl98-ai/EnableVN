@using Domain.Users
@{
    var userId = Context.Session.GetString("UserId");
    var userEmail = Context.Session.GetString("UserEmail");
    var userRole = Context.Session.GetString("UserRole");
    var isLoggedIn = !string.IsNullOrWhiteSpace(userId);
}

<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />

    <title>@ViewData["Title"] - EnableVN</title>

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css"
          rel="stylesheet" />

    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>

<body>
    <header class="evn-navbar">
        <nav class="navbar navbar-expand-lg navbar-light">
            <div class="container">
                <a class="navbar-brand evn-brand" asp-controller="Home" asp-action="Index">
                    <span class="evn-brand-mark">E</span>
                    EnableVN
                </a>

                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#mainNavbar">
                    <span class="navbar-toggler-icon"></span>
                </button>

                <div class="collapse navbar-collapse" id="mainNavbar">
                    <ul class="navbar-nav me-auto mb-2 mb-lg-0">
                        <li class="nav-item">
                            <a class="nav-link" asp-controller="Jobs" asp-action="Index">Việc làm</a>
                        </li>

                        @if (isLoggedIn && userRole == nameof(UserRole.Employer))
                        {
                            <li class="nav-item">
                                <a class="nav-link" asp-controller="EmployerProfile" asp-action="Index">Doanh nghiệp</a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link" asp-controller="EmployerJobs" asp-action="Index">Tin của tôi</a>
                            </li>
                        }

                        @if (isLoggedIn && userRole == nameof(UserRole.Candidate))
                        {
                            <li class="nav-item">
                                <a class="nav-link" asp-controller="CandidateProfile" asp-action="Index">Hồ sơ của tôi</a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link" asp-controller="JobApplications" asp-action="MyApplications">Đã ứng tuyển</a>
                            </li>
                        }
                        @if (isLoggedIn && userRole == nameof(UserRole.Admin))
                        {
                            <li class="nav-item">
                                <a class="nav-link" asp-controller="Catalog" asp-action="Index">
                                    Quản lý danh mục
                                </a>
                            </li>
                        }
                    </ul>

                    <div class="d-flex align-items-center gap-2">
                        @if (isLoggedIn)
                        {
                            <span class="evn-user-chip">
                                @userEmail · @userRole
                            </span>

                            <form asp-controller="Auth" asp-action="Logout" method="post">
                                <button class="btn btn-outline-dark btn-sm" type="submit">
                                    Đăng xuất
                                </button>
                            </form>
                        }
                        else
                        {
                            <a class="btn btn-outline-dark btn-sm" asp-controller="Auth" asp-action="Login">
                                Đăng nhập
                            </a>

                            <a class="btn btn-primary btn-sm evn-btn-primary" asp-controller="Auth" asp-action="Register">
                                Đăng ký
                            </a>
                        }
                    </div>
                </div>
            </div>
        </nav>
    </header>

    <main>
        @if (TempData["Success"] is not null)
        {
            <div class="container mt-3">
                <div class="alert alert-success evn-alert">
                    @TempData["Success"]
                </div>
            </div>
        }

        @if (TempData["Error"] is not null)
        {
            <div class="container mt-3">
                <div class="alert alert-danger evn-alert">
                    @TempData["Error"]
                </div>
            </div>
        }

        @RenderBody()
    </main>

    <footer class="evn-footer">
        <div class="container d-flex flex-column flex-md-row justify-content-between gap-2">
            <span>© @DateTime.Now.Year EnableVN</span>
            <span>Nền tảng tuyển dụng tiếp cận và bao trùm.</span>
        </div>
    </footer>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>