@model int

<a class="btn btn-outline-secondary btn-sm evn-notification-bell d-inline-flex d-md-none"
   asp-controller="Notifications"
   asp-action="Index"
   aria-label="Thông báo, @Model chưa đọc">
    <i class="bi bi-bell" aria-hidden="true"></i>
    @if (Model > 0)
    {
        <span class="evn-notification-badge" aria-hidden="true">@Model</span>
    }
</a>
