@{
    ViewData["Title"] = "Quản lý danh mục";
    var crumb = new BreadcrumbModel { MiddleText = "Admin", MiddleController = "AdminDashboard", MiddleAction = "Index", CurrentText = "Danh mục" };
}

<div class="evn-page">
    <div class="container py-4">
        <partial name="_Breadcrumb" model="crumb" />
        <header class="evn-page-head mb-4">
            <span class="evn-badge mb-2">Admin</span>
            <h1 class="evn-page-head__title">Quản lý danh mục hệ thống</h1>
            <p class="evn-page-head__lead mb-0">
                Dữ liệu nền tảng dùng trong hồ sơ ứng viên và tin tuyển dụng.
            </p>
        </header>

        <div class="row g-4">
            <div class="col-lg-4">
                <div class="evn-card p-4 h-100">
                    <h2 class="h5 fw-bold">Loại khuyết tật</h2>
                    <p class="evn-muted">
                        Danh mục để ứng viên chọn trong hồ sơ.
                    </p>
                    <a class="btn btn-primary evn-btn-primary"
                       asp-controller="Catalog"
                       asp-action="DisabilityTypes">
                        Quản lý
                    </a>
                </div>
            </div>

            <div class="col-lg-4">
                <div class="evn-card p-4 h-100">
                    <h2 class="h5 fw-bold">Thiết bị hỗ trợ</h2>
                    <p class="evn-muted">
                        Danh mục thiết bị hỗ trợ (screen reader, xe lăn…).
                    </p>
                    <a class="btn btn-primary evn-btn-primary"
                       asp-controller="Catalog"
                       asp-action="AssistiveDevices">
                        Quản lý
                    </a>
                </div>
            </div>

            <div class="col-lg-4">
                <div class="evn-card p-4 h-100">
                    <h2 class="h5 fw-bold">Ngành nghề</h2>
                    <p class="evn-muted">
                        Nhóm công việc phục vụ tìm kiếm và lọc.
                    </p>
                    <a class="btn btn-primary evn-btn-primary"
                       asp-controller="Catalog"
                       asp-action="JobCategories">
                        Quản lý
                    </a>
                </div>
            </div>
        </div>
    </div>
</div>
