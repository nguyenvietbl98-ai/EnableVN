@model IReadOnlyList<CatalogItemResult>

@{
    ViewData["Title"] = ViewBag.CatalogTitle;
    var createAction = (string)ViewBag.CreateAction;
    var editAction = (string)ViewBag.EditAction;
    var deactivateAction = (string)ViewBag.DeactivateAction;
}

<section class="evn-section">
    <div class="container">
        <div class="d-flex flex-column flex-lg-row justify-content-between gap-3 mb-4">
            <div>
                <span class="evn-badge mb-3">Admin Catalog</span>
                <h1 class="fw-bold display-6 mb-2">@ViewBag.CatalogTitle</h1>
                <p class="evn-muted mb-0">
                    Quản lý dữ liệu danh mục đang hoạt động trong hệ thống.
                </p>
            </div>

            <div class="d-flex align-items-start gap-2">
                <a class="btn btn-outline-dark"
                       asp-controller="Catalog"
                       asp-action="Index">
                    Quay lại
                </a>

                <a class="btn btn-primary evn-btn-primary"
                       asp-controller="Catalog"
                       asp-action="@createAction">
                    Tạo mới
                </a>
            </div>
        </div>

        @if (Model.Count == 0)
        {
            <div class="evn-card p-5 text-center">
                <h4 class="fw-bold">Chưa có dữ liệu</h4>
                <p class="evn-muted">
                    Hãy tạo danh mục đầu tiên để hệ thống có dữ liệu sử dụng.
                </p>

                <a class="btn btn-primary evn-btn-primary"
                       asp-controller="Catalog"
                       asp-action="@createAction">
                    Tạo mới
                </a>
            </div>
        }
        else
        {
            <div class="evn-card p-0 overflow-hidden">
                <div class="table-responsive">
                    <table class="table align-middle mb-0">
                        <thead>
                            <tr>
                                <th class="p-4">Tên</th>
                                <th>Mô tả</th>
                                <th>Trạng thái</th>
                                <th class="text-end p-4">Thao tác</th>
                            </tr>
                        </thead>

                        <tbody>
                            @foreach (var item in Model)
                            {
                                <tr>
                                    <td class="p-4 fw-semibold">
                                        @item.Name
                                    </td>

                                    <td>
                                        @(string.IsNullOrWhiteSpace(item.Description)
                                            ? "Không có mô tả"
                                            : item.Description)
                                    </td>

                                    <td>
                                        <span class="evn-badge">@item.Status</span>
                                    </td>

                                    <td class="text-end p-4">
                                        <a class="btn btn-outline-dark btn-sm"
                                               asp-controller="Catalog"
                                               asp-action="@editAction"
                                               asp-route-id="@item.Id"
                                               asp-route-name="@item.Name"
                                               asp-route-description="@item.Description">
                                            Sửa
                                        </a>

                                        <form asp-controller="Catalog"
                                              asp-action="@deactivateAction"
                                              method="post"
                                              class="d-inline">
                                            <input type="hidden" name="id" value="@item.Id" />
                                            <button class="btn btn-outline-danger btn-sm" type="submit">
                                                Tắt
                                            </button>
                                        </form>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        }
    </div>
</section>