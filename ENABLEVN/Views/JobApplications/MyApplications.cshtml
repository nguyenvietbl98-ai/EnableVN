@model IReadOnlyList<JobApplicationResult>
@{
    ViewData["Title"] = "Hồ sơ đã ứng tuyển";
    var crumb = new BreadcrumbModel { MiddleText = "Dashboard", MiddleController = "CandidateDashboard", MiddleAction = "Index", CurrentText = "Đơn ứng tuyển" };
    string StatusVi(ApplicationStatus s) => s switch
    {
        ApplicationStatus.Pending => "Chờ xử lý",
        ApplicationStatus.Reviewing => "Đang xem xét",
        ApplicationStatus.Interview => "Phỏng vấn",
        ApplicationStatus.Rejected => "Từ chối",
        ApplicationStatus.Accepted => "Đã nhận",
        ApplicationStatus.Withdrawn => "Đã rút",
        _ => s.ToString()
    };
}

<div class="evn-page">
    <div class="container py-4">
        <partial name="_Breadcrumb" model="crumb" />
        <header class="evn-page-head mb-4">
            <span class="evn-badge mb-2">Candidate</span>
            <h1 class="evn-page-head__title">Hồ sơ đã ứng tuyển</h1>
            <p class="evn-page-head__lead mb-0">Theo dõi trạng thái và liên kết tới tin tuyển dụng.</p>
        </header>

        @if (Model.Count == 0)
        {
            <div class="evn-empty" role="status">
                <h2 class="evn-empty__title">Bạn chưa nộp hồ sơ nào</h2>
                <p class="evn-empty__text">Tìm việc phù hợp và ứng tuyển ngay trên EnableVN.</p>
                <a class="btn btn-primary evn-btn-primary" asp-controller="Jobs" asp-action="Index">Tìm việc</a>
            </div>
        }
        else
        {
            <div class="evn-table-wrap">
                <div class="table-responsive">
                    <table class="table evn-data-table align-middle mb-0">
                        <thead>
                            <tr>
                                <th scope="col">Việc làm</th>
                                <th scope="col">Trạng thái</th>
                                <th scope="col">Ngày nộp</th>
                                <th scope="col" class="text-end">Thao tác</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var item in Model)
                            {
                                <tr>
                                    <td>
                                        <a asp-controller="Jobs" asp-action="Details" asp-route-id="@item.JobId">Xem tin tuyển dụng</a>
                                        <div class="small evn-muted mt-1">Mã hồ sơ: <code>@item.Id</code></div>
                                    </td>
                                    <td>
                                        <span class="evn-tag">@StatusVi(item.Status)</span>
                                        <span class="visually-hidden"> (@item.Status)</span>
                                    </td>
                                    <td>@item.SubmittedAt.ToString("dd/MM/yyyy HH:mm")</td>
                                    <td class="text-end">
                                        @if (item.Status != ApplicationStatus.Withdrawn &&
                                             item.Status != ApplicationStatus.Accepted &&
                                             item.Status != ApplicationStatus.Rejected)
                                        {
                                            <form asp-action="Withdraw" method="post" class="d-inline">
                                                @Html.AntiForgeryToken()
                                                <input type="hidden" name="applicationId" value="@item.Id" />
                                                <button class="btn btn-outline-secondary btn-sm" type="submit">Rút hồ sơ</button>
                                            </form>
                                        }
                                        else
                                        {
                                            <span class="evn-muted small">—</span>
                                        }
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        }
    </div>
</div>
