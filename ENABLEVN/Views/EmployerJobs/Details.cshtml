@using Domain.Jobs
@model Ports.Models.Jobs.JobResult
@{
    ViewData["Title"] = Model.Title;
    string JobStatusVi(JobStatus s) => s switch
    {
        JobStatus.Draft => "Nháp",
        JobStatus.Published => "Đang tuyển",
        JobStatus.Closed => "Đã đóng",
        JobStatus.Deleted => "Đã xóa",
        _ => s.ToString()
    };
    string WorkModeVi(WorkMode w) => w switch
    {
        WorkMode.Onsite => "Tại văn phòng",
        WorkMode.Remote => "Làm từ xa",
        WorkMode.Hybrid => "Kết hợp",
        _ => w.ToString()
    };
    var crumb = new BreadcrumbModel { MiddleText = "Tin tuyển dụng", MiddleController = "EmployerJobs", MiddleAction = "Index", CurrentText = Model.Title };
}

<div class="evn-page employer-jobs-page">
    <div class="container py-4">
        <partial name="_Breadcrumb" model="crumb" />

        <header class="evn-card p-4 p-lg-5 mb-4">
            <div class="d-flex flex-column flex-lg-row justify-content-between gap-3 align-items-start">
                <div>
                    <span class="evn-badge mb-2">Employer</span>
                    <h1 class="evn-page-head__title mb-2">@Model.Title</h1>
                    <p class="evn-muted mb-2">
                        <span class="evn-tag me-2">@JobStatusVi(Model.Status)</span>
                        <span class="visually-hidden">Trạng thái hệ thống: </span>
                        <span class="small">(@Model.Status)</span>
                    </p>
                    <p class="evn-muted small mb-0">
                        Hình thức: <strong>@WorkModeVi(Model.WorkMode)</strong>
                        · Đăng: @(Model.PublishedAt?.ToString("dd/MM/yyyy HH:mm") ?? "—")
                    </p>
                </div>
                <div class="d-flex flex-wrap gap-2">
                    <a class="btn btn-outline-secondary" asp-action="Index">Danh sách tin</a>
                    <a class="btn btn-outline-primary" asp-controller="JobApplications" asp-action="ByJob" asp-route-jobId="@Model.Id">Hồ sơ ứng tuyển</a>
                    <a class="btn btn-primary evn-btn-primary" asp-action="Edit" asp-route-id="@Model.Id">Sửa tin</a>
                </div>
            </div>
        </header>

        <div class="row g-4 mb-4">
            <div class="col-lg-8">
                <div class="evn-card p-4 p-lg-5 h-100">
                    <h2 class="h5 fw-bold mb-3">Mô tả công việc</h2>
                    <p class="evn-muted">@Model.Description</p>
                    <h2 class="h5 fw-bold mt-4 mb-3">Yêu cầu</h2>
                    <p class="evn-muted mb-0">@Model.Requirement</p>
                </div>
            </div>
            <div class="col-lg-4">
                <div class="evn-card-soft p-4 h-100">
                    <h2 class="h6 fw-bold mb-3">Lương</h2>
                    <p class="mb-4">
                        @if (Model.MinSalary.HasValue || Model.MaxSalary.HasValue)
                        {
                            <span>@(Model.MinSalary?.ToString("N0") ?? "—") – @(Model.MaxSalary?.ToString("N0") ?? "—") <span class="evn-muted small">VNĐ</span></span>
                        }
                        else
                        {
                            <span>Thỏa thuận</span>
                        }
                    </p>
                    <h2 class="h6 fw-bold mb-3">Hỗ trợ tiếp cận</h2>
                    <ul class="list-unstyled d-grid gap-2 small mb-0">
                        <li>Xe lăn: <strong>@(Model.SupportsWheelchairAccess ? "Có" : "Không")</strong></li>
                        <li>Remote: <strong>@(Model.SupportsRemoteWork ? "Có" : "Không")</strong></li>
                        <li>Thời gian linh hoạt: <strong>@(Model.SupportsFlexibleTime ? "Có" : "Không")</strong></li>
                        <li>Thiết bị hỗ trợ: <strong>@(Model.ProvidesAssistiveDevices ? "Có" : "Không")</strong></li>
                    </ul>
                    @if (!string.IsNullOrWhiteSpace(Model.AdditionalSupportDescription))
                    {
                        <hr class="my-3" />
                        <p class="evn-muted small mb-0">@Model.AdditionalSupportDescription</p>
                    }
                </div>
            </div>
        </div>

        <div class="evn-card p-4">
            <h2 class="h6 fw-bold mb-3">Thao tác tin</h2>
            <div class="d-flex flex-column flex-md-row flex-wrap gap-2">
                @if (Model.Status == JobStatus.Draft)
                {
                    <form asp-action="Publish" method="post" class="d-inline">
                        @Html.AntiForgeryToken()
                        <input type="hidden" name="id" value="@Model.Id" />
                        <button type="submit" class="btn btn-success">Đăng tin</button>
                    </form>
                }
                @if (Model.Status == JobStatus.Published)
                {
                    <form asp-action="Close" method="post" class="d-inline">
                        @Html.AntiForgeryToken()
                        <input type="hidden" name="id" value="@Model.Id" />
                        <button type="submit" class="btn btn-warning">Đóng tin</button>
                    </form>
                }
                <form asp-action="Delete" method="post" class="d-inline-flex flex-column align-items-start gap-2">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="id" value="@Model.Id" />
                    <fieldset class="border-0 p-0 m-0">
                        <legend class="visually-hidden">Xóa tin tuyển dụng</legend>
                        <label class="d-flex align-items-center gap-2 small text-danger mb-0">
                            <input type="checkbox" name="confirmDelete" required aria-required="true" />
                            Tôi xác nhận muốn xóa tin này
                        </label>
                    </fieldset>
                    <button type="submit" class="btn btn-outline-danger">Xóa tin</button>
                </form>
            </div>
        </div>
    </div>
</div>
