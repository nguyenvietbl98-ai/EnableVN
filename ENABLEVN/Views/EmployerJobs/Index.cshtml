@using Domain.Jobs
@model IReadOnlyList<Ports.Models.Jobs.JobResult>

@{
    ViewData["Title"] = "Tin tuyển dụng của tôi";
}

<section class="page-section">
    <div class="page-header">
        <p class="eyebrow">Employer</p>
        <h1>Tin tuyển dụng của tôi</h1>
        <p>Quản lý các tin nháp, tin đang đăng và tin đã đóng.</p>
    </div>

    <p>
        <a asp-action="Create" class="btn btn-primary">Tạo tin mới</a>
    </p>

    @if (Model.Count == 0)
    {
        <div class="empty-state">
            <h2>Bạn chưa có tin tuyển dụng</h2>
            <p>Hãy tạo tin đầu tiên để ứng viên có thể tìm thấy.</p>
            <a asp-action="Create" class="btn btn-primary">Tạo tin</a>
        </div>
    }
    else
    {
        <div class="card-grid">
            @foreach (var job in Model)
            {
                <article class="job-card">
                    <div class="job-card-header">
                        <h2>@job.Title</h2>
                        <span class="badge">@job.Status</span>
                    </div>

                    <p class="muted">@job.WorkMode</p>

                    <p>
                        @(job.Description.Length > 150
                            ? job.Description[..150] + "..."
                            : job.Description)
                    </p>

                    <div class="tag-row" aria-label="Các hỗ trợ tiếp cận">
                        @if (job.SupportsRemoteWork)
                        {
                            <span class="tag">Remote</span>
                        }
                        @if (job.SupportsWheelchairAccess)
                        {
                            <span class="tag">Xe lăn</span>
                        }
                        @if (job.SupportsFlexibleTime)
                        {
                            <span class="tag">Linh hoạt</span>
                        }
                        @if (job.ProvidesAssistiveDevices)
                        {
                            <span class="tag">Thiết bị hỗ trợ</span>
                        }
                    </div>

                    <div class="card-actions">
                        <a asp-action="Details" asp-route-id="@job.Id" class="btn btn-secondary">Xem</a>
                        <a asp-action="Edit" asp-route-id="@job.Id" class="btn btn-secondary">Sửa</a>
                        <a asp-controller="JobApplications"
                               asp-action="ByJob"
                               asp-route-jobId="@job.Id"
                               class="btn btn-secondary">
                            Hồ sơ ứng tuyển
                        </a>

                        @if (job.Status == JobStatus.Draft)
                        {
                            <form asp-action="Publish" method="post" class="inline-form">
                                @Html.AntiForgeryToken()
                                <input type="hidden" name="id" value="@job.Id" />
                                <button type="submit" class="btn btn-success">Đăng tin</button>
                            </form>
                        }

                        @if (job.Status == JobStatus.Published)
                        {
                            <form asp-action="Close" method="post" class="inline-form">
                                @Html.AntiForgeryToken()
                                <input type="hidden" name="id" value="@job.Id" />
                                <button type="submit" class="btn btn-warning">Đóng tin</button>
                            </form>
                        }

                        <form asp-action="Delete" method="post" class="inline-form"
                              onsubmit="return confirm('Bạn có chắc muốn xóa tin này không?');">
                            @Html.AntiForgeryToken()
                            <input type="hidden" name="id" value="@job.Id" />
                            <button type="submit" class="btn btn-danger">Xóa</button>
                        </form>
                    </div>
                </article>
            }
        </div>
    }
</section>