@model CreateJobCommand

@{
    ViewData["Title"] = "Tạo tin tuyển dụng";
    var crumb = new BreadcrumbModel { MiddleText = "Tin tuyển dụng", MiddleController = "EmployerJobs", MiddleAction = "Index", CurrentText = "Tạo tin" };
}

<div class="evn-page employer-jobs-page">
    <div class="container py-4">
        <partial name="_Breadcrumb" model="crumb" />
        <div class="row justify-content-center">
            <div class="col-lg-8">
                <div class="evn-card evn-form p-4 p-lg-5 position-relative">
                    <div class="d-flex flex-wrap justify-content-between align-items-start gap-2 mb-2">
                        <div>
                            <span class="evn-badge mb-2 d-inline-block">Employer</span>
                            <h1 class="h3 fw-bold mb-2">Tạo tin tuyển dụng</h1>
                        </div>
                        <button type="button" class="btn btn-outline-primary btn-sm shrink-0" data-bs-toggle="modal" data-bs-target="#evn-jd-ai-modal">
                            <i class="bi bi-stars me-1" aria-hidden="true"></i> Phân tích JD (AI)
                        </button>
                    </div>
                    <p class="evn-muted mb-4">
                        Tin sẽ được tạo ở trạng thái nháp. Bạn có thể đăng tin sau. Dán JD dài từ Word — AI điền form (Gemini), bạn kiểm tra trước khi lưu.
                    </p>

                    <form asp-action="Create" method="post" id="evn-employer-job-create-form">
                        @Html.AntiForgeryToken()
                        <div class="mb-3">
                            <label asp-for="Title" class="form-label">Tiêu đề</label>
                            <input asp-for="Title" class="form-control" placeholder="VD: Frontend Developer" />
                        </div>

                        <div class="mb-3">
                            <label asp-for="Description" class="form-label">Mô tả công việc</label>
                            <textarea asp-for="Description" class="form-control" rows="5"></textarea>
                        </div>

                        <div class="mb-3">
                            <label asp-for="Requirement" class="form-label">Yêu cầu</label>
                            <textarea asp-for="Requirement" class="form-control" rows="4"></textarea>
                        </div>

                        <div class="row g-3">
                            <div class="col-md-4">
                                <label asp-for="WorkMode" class="form-label">Hình thức</label>
                                <select asp-for="WorkMode" class="form-select">
                                    <option value="@WorkMode.Onsite">Tại văn phòng</option>
                                    <option value="@WorkMode.Remote">Làm từ xa</option>
                                    <option value="@WorkMode.Hybrid">Kết hợp</option>
                                </select>
                            </div>

                            <div class="col-md-4">
                                <label asp-for="MinSalary" class="form-label">Lương tối thiểu (VNĐ)</label>
                                <input asp-for="MinSalary" class="form-control" type="number" min="0" step="100000" />
                            </div>

                            <div class="col-md-4">
                                <label asp-for="MaxSalary" class="form-label">Lương tối đa (VNĐ)</label>
                                <input asp-for="MaxSalary" class="form-control" type="number" min="0" step="100000" />
                            </div>
                        </div>

                        <hr class="my-4" />

                        <h5 class="fw-bold mb-3">Hỗ trợ tiếp cận</h5>

                        <div class="row g-3 mb-3">
                            <div class="col-md-6">
                                <label class="form-check">
                                    <input asp-for="SupportsWheelchairAccess" class="form-check-input" />
                                    <span class="form-check-label">Hỗ trợ xe lăn</span>
                                </label>
                            </div>

                            <div class="col-md-6">
                                <label class="form-check">
                                    <input asp-for="SupportsRemoteWork" class="form-check-input" />
                                    <span class="form-check-label">Hỗ trợ làm việc từ xa</span>
                                </label>
                            </div>

                            <div class="col-md-6">
                                <label class="form-check">
                                    <input asp-for="SupportsFlexibleTime" class="form-check-input" />
                                    <span class="form-check-label">Thời gian linh hoạt</span>
                                </label>
                            </div>

                            <div class="col-md-6">
                                <label class="form-check">
                                    <input asp-for="ProvidesAssistiveDevices" class="form-check-input" />
                                    <span class="form-check-label">Có thiết bị hỗ trợ</span>
                                </label>
                            </div>
                        </div>

                        <div class="mb-4">
                            <label asp-for="AdditionalSupportDescription" class="form-label">Mô tả hỗ trợ thêm</label>
                            <textarea asp-for="AdditionalSupportDescription" class="form-control" rows="3"></textarea>
                        </div>

                        <button class="btn btn-primary evn-btn-primary" type="submit">
                            Tạo tin nháp
                        </button>

                        <a class="btn btn-outline-secondary" asp-action="Index">
                            Hủy
                        </a>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

<div class="modal fade" id="evn-jd-ai-modal" tabindex="-1" aria-labelledby="evn-jd-ai-title" aria-hidden="true">
    <div class="modal-dialog modal-lg modal-dialog-scrollable">
        <div class="modal-content">
            <div class="modal-header">
                <h2 class="modal-title h5" id="evn-jd-ai-title">Phân tích JD bằng AI (Gemini)</h2>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Đóng"></button>
            </div>
            <div class="modal-body">
                <label for="evn-jd-paste" class="form-label">Dán nội dung tin / JD</label>
                <textarea id="evn-jd-paste" class="form-control" rows="12" maxlength="32000" placeholder="Dán toàn bộ mô tả công việc từ Word hoặc email tuyển dụng…"></textarea>
                <p id="evn-jd-error" class="small text-danger mt-2 mb-0" role="alert"></p>
                <div id="evn-jd-bias" class="mt-3"></div>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">Đóng</button>
                <button type="button" class="btn btn-primary evn-btn-primary" onclick="evnParseJdFromModal()">Phân tích &amp; điền form</button>
            </div>
        </div>
    </div>
</div>