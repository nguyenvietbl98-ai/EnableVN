@model IReadOnlyList<Ports.Models.Notifications.NotificationResult>
@using Domain.Notifications

@{
    ViewData["Title"] = "Thông báo";
}

<div class="container py-4">
    <div class="d-flex flex-column flex-md-row align-items-md-end justify-content-between gap-2 mb-3">
        <div>
            <h1 class="mb-1">Thông báo</h1>
            <p class="evn-muted mb-0">Cập nhật mới nhất dành cho tài khoản của bạn.</p>
        </div>
    </div>

    @if (!Model.Any())
    {
        <div class="evn-card p-4">
            <p class="mb-1 fw-semibold">Chưa có thông báo</p>
            <p class="evn-muted mb-0">
                Khi có cập nhật (nộp hồ sơ, đổi trạng thái, v.v.), bạn sẽ thấy thông báo ở đây.
            </p>
        </div>
    }
    else
    {
        <div class="notification-list">
            @foreach (var item in Model)
            {
                <article class="evn-card mb-3"
                         aria-label="Thông báo @item.Title">
                    <div class="card-body">
                        <h2 class="h5 d-flex align-items-center gap-2">
                            <span>@item.Title</span>

                            @if (item.Status == NotificationStatus.Unread)
                            {
                                <span class="badge bg-warning text-dark">Chưa đọc</span>
                            }
                        </h2>

                        <p class="mb-2">@item.Message</p>

                        <p class="text-muted mb-3">
                            @item.CreatedAt.ToLocalTime().ToString("dd/MM/yyyy HH:mm")
                        </p>

                        @if (item.Status == NotificationStatus.Unread)
                        {
                            <form asp-action="MarkAsRead" method="post">
                                @Html.AntiForgeryToken()

                                <input type="hidden" name="id" value="@item.Id" />

                                <button type="submit" class="btn btn-primary evn-btn-primary">
                                    Đánh dấu đã đọc
                                </button>
                            </form>
                        }
                    </div>
                </article>
            }
        </div>
    }
</div>